<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Copybara Hub - Web Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        }
        body {
            background: linear-gradient(135deg, #0a0f1a 0%, #0c1220 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .dashboard {
            max-width: 650px;
            width: 100%;
            background: rgba(18, 22, 35, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            border: 1px solid rgba(100, 150, 255, 0.2);
            box-shadow: 0 25px 45px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.02);
            overflow: hidden;
            transition: all 0.2s;
        }
        .header {
            background: rgba(10, 14, 23, 0.9);
            padding: 20px 28px;
            border-bottom: 1px solid #1e2a3a;
        }
        .header h1 {
            font-size: 26px;
            font-weight: 700;
            background: linear-gradient(135deg, #a0c0ff, #6080ff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.3px;
        }
        .header p {
            color: #8f9bb3;
            font-size: 13px;
            margin-top: 6px;
        }
        .content {
            padding: 24px 28px 32px;
        }
        .section {
            margin-bottom: 28px;
            border-bottom: 1px solid #1e2a3a;
            padding-bottom: 20px;
        }
        .section-title {
            font-size: 18px;
            font-weight: 600;
            color: #cbd5ff;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .section-title i {
            font-size: 20px;
        }
        .setting-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            flex-wrap: wrap;
            gap: 12px;
        }
        .setting-label {
            font-weight: 500;
            color: #e2e8ff;
            font-size: 15px;
            flex: 2;
        }
        .setting-control {
            flex: 1;
            min-width: 140px;
            display: flex;
            justify-content: flex-end;
        }
        /* Toggle Switch */
        .switch {
            position: relative;
            display: inline-block;
            width: 52px;
            height: 26px;
        }
        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #2d3748;
            transition: 0.2s;
            border-radius: 34px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: 0.2s;
            border-radius: 50%;
        }
        input:checked + .slider {
            background-color: #3b82f6;
        }
        input:checked + .slider:before {
            transform: translateX(26px);
        }
        /* Slider */
        input[type="range"] {
            width: 160px;
            height: 4px;
            -webkit-appearance: none;
            background: #2d3748;
            border-radius: 5px;
            outline: none;
        }
        input[type="range"]:focus {
            outline: none;
        }
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #6080ff;
            cursor: pointer;
            box-shadow: 0 0 4px #6080ff;
        }
        .value-display {
            margin-left: 12px;
            background: #1e2a3a;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
            color: #a0c0ff;
            min-width: 45px;
            text-align: center;
        }
        /* Color picker */
        .color-preview {
            width: 40px;
            height: 32px;
            border-radius: 10px;
            border: 1px solid #2d4379;
            cursor: pointer;
            background: #ff4444;
        }
        input[type="color"] {
            width: 40px;
            height: 32px;
            border: none;
            background: transparent;
            cursor: pointer;
        }
        .json-output {
            background: #0a0e17;
            border-radius: 20px;
            padding: 16px;
            margin-top: 20px;
            border: 1px solid #25324f;
        }
        .json-title {
            font-size: 13px;
            color: #7f8ea3;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        pre {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            color: #bbd9ff;
            overflow-x: auto;
            white-space: pre-wrap;
            word-wrap: break-word;
            background: #03060c;
            padding: 12px;
            border-radius: 14px;
        }
        button {
            background: #2c3e66;
            border: none;
            padding: 10px 18px;
            border-radius: 40px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: 0.2s;
            font-size: 14px;
        }
        button:hover {
            background: #3b5b9e;
            transform: scale(0.98);
        }
        .save-btn {
            background: #3b82f6;
            width: 100%;
            margin-top: 16px;
            padding: 12px;
            font-size: 16px;
        }
        footer {
            text-align: center;
            padding: 16px;
            font-size: 12px;
            color: #5b6e8c;
            border-top: 1px solid #1e2a3a;
        }
        @media (max-width: 550px) {
            .content { padding: 16px; }
            .setting-row { flex-direction: column; align-items: flex-start; }
            .setting-control { justify-content: flex-start; width: 100%; }
        }
    </style>
</head>
<body>
<div class="dashboard">
    <div class="header">
        <h1>🦫 Copybara Hub · Web Control</h1>
        <p>Remote configuration — save settings & use JSON in Roblox</p>
    </div>
    <div class="content">
        <div class="section">
            <div class="section-title">🎯 Aimbot & Weapons</div>
            <div class="setting-row">
                <span class="setting-label">Aimbot (100% Headshot)</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="aimbotToggle"><span class="slider"></span></label></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">Aimbot FOV (degrees)</span>
                <div class="setting-control"><input type="range" id="aimbotFOV" min="30" max="300" value="120"><span id="fovValue" class="value-display">120</span></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">No Recoil</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="noRecoilToggle"><span class="slider"></span></label></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">No Spread</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="noSpreadToggle"><span class="slider"></span></label></div>
            </div>
        </div>

        <div class="section">
            <div class="section-title">👁️ Visual & Wallhack</div>
            <div class="setting-row">
                <span class="setting-label">Player Wallhack (Red)</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="playerWallhackToggle"><span class="slider"></span></label></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">NPC Wallhack (Yellow)</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="npcWallhackToggle"><span class="slider"></span></label></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">Wallhack Color (Player)</span>
                <div class="setting-control"><input type="color" id="wallhackColor" value="#ff4444"></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">Player ESP (Transparent)</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="playerEspToggle"><span class="slider"></span></label></div>
            </div>
        </div>

        <div class="section">
            <div class="section-title">⚡ Movement & Player</div>
            <div class="setting-row">
                <span class="setting-label">Infinite Jump</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="infiniteJumpToggle"><span class="slider"></span></label></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">Noclip</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="noclipToggle"><span class="slider"></span></label></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">Walk Speed</span>
                <div class="setting-control"><input type="range" id="walkSpeed" min="16" max="200" value="16"><span id="wsValue" class="value-display">16</span></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">Jump Power</span>
                <div class="setting-control"><input type="range" id="jumpPower" min="50" max="500" step="10" value="50"><span id="jpValue" class="value-display">50</span></div>
            </div>
        </div>

        <div class="section">
            <div class="section-title">⚔️ Combat</div>
            <div class="setting-row">
                <span class="setting-label">Kill Aura (Players)</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="killAuraPlayerToggle"><span class="slider"></span></label></div>
            </div>
            <div class="setting-row">
                <span class="setting-label">Auto Kill NPCs</span>
                <div class="setting-control"><label class="switch"><input type="checkbox" id="autoKillNpcToggle"><span class="slider"></span></label></div>
            </div>
        </div>

        <div class="json-output">
            <div class="json-title">
                <span>📋 Configuration JSON (copy this to Roblox)</span>
                <button id="copyBtn" style="background:#1e2a3a; padding:4px 12px;">Copy</button>
            </div>
            <pre id="jsonPreview">{
  "aimbot": false,
  "aimbotFOV": 120,
  "noRecoil": false,
  ...
}</pre>
        </div>
        <button id="saveBtn" class="save-btn">💾 Save Settings & Update JSON</button>
    </div>
    <footer>Copybara Hub Web Dashboard · Sync with Roblox via HttpService</footer>
</div>

<script>
    // DOM elements
    const aimbotToggle = document.getElementById('aimbotToggle');
    const aimbotFOV = document.getElementById('aimbotFOV');
    const fovValue = document.getElementById('fovValue');
    const noRecoilToggle = document.getElementById('noRecoilToggle');
    const noSpreadToggle = document.getElementById('noSpreadToggle');
    const playerWallhackToggle = document.getElementById('playerWallhackToggle');
    const npcWallhackToggle = document.getElementById('npcWallhackToggle');
    const wallhackColor = document.getElementById('wallhackColor');
    const playerEspToggle = document.getElementById('playerEspToggle');
    const infiniteJumpToggle = document.getElementById('infiniteJumpToggle');
    const noclipToggle = document.getElementById('noclipToggle');
    const walkSpeed = document.getElementById('walkSpeed');
    const wsValue = document.getElementById('wsValue');
    const jumpPower = document.getElementById('jumpPower');
    const jpValue = document.getElementById('jpValue');
    const killAuraPlayerToggle = document.getElementById('killAuraPlayerToggle');
    const autoKillNpcToggle = document.getElementById('autoKillNpcToggle');
    const jsonPreview = document.getElementById('jsonPreview');
    const saveBtn = document.getElementById('saveBtn');
    const copyBtn = document.getElementById('copyBtn');

    // update value displays
    aimbotFOV.addEventListener('input', () => {
        fovValue.innerText = aimbotFOV.value;
        updateJSON();
    });
    walkSpeed.addEventListener('input', () => {
        wsValue.innerText = walkSpeed.value;
        updateJSON();
    });
    jumpPower.addEventListener('input', () => {
        jpValue.innerText = jumpPower.value;
        updateJSON();
    });
    
    const allToggles = [aimbotToggle, noRecoilToggle, noSpreadToggle, playerWallhackToggle, npcWallhackToggle, playerEspToggle, infiniteJumpToggle, noclipToggle, killAuraPlayerToggle, autoKillNpcToggle];
    allToggles.forEach(t => t.addEventListener('change', updateJSON));
    wallhackColor.addEventListener('input', updateJSON);
    
    function getConfig() {
        return {
            aimbot: aimbotToggle.checked,
            aimbotFOV: parseInt(aimbotFOV.value),
            noRecoil: noRecoilToggle.checked,
            noSpread: noSpreadToggle.checked,
            playerWallhack: playerWallhackToggle.checked,
            npcWallhack: npcWallhackToggle.checked,
            wallhackColor: wallhackColor.value,
            playerESP: playerEspToggle.checked,
            infiniteJump: infiniteJumpToggle.checked,
            noclip: noclipToggle.checked,
            walkSpeed: parseInt(walkSpeed.value),
            jumpPower: parseInt(jumpPower.value),
            killAuraPlayer: killAuraPlayerToggle.checked,
            autoKillNPC: autoKillNpcToggle.checked
        };
    }
    
    function updateJSON() {
        const config = getConfig();
        jsonPreview.innerText = JSON.stringify(config, null, 2);
    }
    
    saveBtn.addEventListener('click', () => {
        updateJSON();
        // optional: you could also save to localStorage
        alert('✅ Settings saved! Copy the JSON above and use in Roblox via HttpService.');
    });
    
    copyBtn.addEventListener('click', () => {
        const text = jsonPreview.innerText;
        navigator.clipboard.writeText(text).then(() => {
            alert('JSON copied to clipboard!');
        }).catch(() => {
            alert('Manual copy: select the text.');
        });
    });
    
    // initial update
    updateJSON();
</script>
</body>
</html>
